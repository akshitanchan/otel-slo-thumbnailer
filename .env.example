# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thumbnailer

# API
PORT=8080
STORAGE_DIR=/data

# Worker
# PORT=8081  (worker uses a separate port)
POLL_MS=200
CLAIM_BACKOFF_MS=500

# OpenTelemetry (override if not using the bundled collector)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces

# DB tuning — these are already conservative defaults, but you can tighten them
# DB_CONNECT_TIMEOUT_MS=2000
# DB_STATEMENT_TIMEOUT_MS=2000
