{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "API RPS",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api\"}[30s]))",
          "legendFormat": "rps"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "API Latency (p50/p95/p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(http_request_duration_seconds_bucket{service=\"api\",method=\"POST\",route=\"/v1/thumbnails\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"api\",method=\"POST\",route=\"/v1/thumbnails\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"api\",method=\"POST\",route=\"/v1/thumbnails\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "title": "API Error Rate (5xx)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(sum(rate(http_requests_total{service=\"api\",status_code=~\"5..\"}[1m])) / sum(rate(http_requests_total{service=\"api\"}[1m]))) or vector(0)",
          "legendFormat": "error %"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Readiness",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "thumbnailer_ready",
          "legendFormat": "api"
        },
        {
          "expr": "worker_ready",
          "legendFormat": "worker"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "id": 5,
      "title": "Worker Jobs Claimed / Completed",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(jobs_claimed_total[30s])",
          "legendFormat": "claimed/s"
        },
        {
          "expr": "sum by (result) (rate(jobs_completed_total[30s]))",
          "legendFormat": "completed/s ({{result}})"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "id": 6,
      "title": "Job End-to-End Latency (p50/p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(job_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(job_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 7,
      "title": "DB Query Latency p95",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{service=\"api\"}[1m])) by (le))",
          "legendFormat": "api"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket{service=\"worker\"}[1m])) by (le))",
          "legendFormat": "worker"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    },
    {
      "id": 8,
      "title": "Queue Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "queue_depth",
          "legendFormat": "queued"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }
    },
    {
      "id": 9,
      "title": "Jobs Stuck",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jobs_stuck",
          "legendFormat": "stuck"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 }
    },
    {
      "id": 10,
      "title": "Postgres Up",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "postgres"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 }
    }
  ],
